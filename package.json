{
  "name": "transparent-proxy",
  "description": "透明 HTTP 转发代理服务器，支持基于配置的路由与日志记录",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm",
  "scripts": {
    "start": "tsx src/index.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test **/*.test.ts",
    "build": "vite build",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": "【当前项目不支持直接使用npm，请使用pnpm】",
    "yarn": "【当前项目不支持使用yarn，请使用pnpm】",
    "pnpm": "*"
  },
  "dependencies": {
    "commander": "14.0.3",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.3"
  }
}
